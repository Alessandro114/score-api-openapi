          "protocol": "https",
          "host": ["score", "get-scala", "com"],
          "path": ["api", "lookup"],
          "query": [
            { "key": "id", "value": "IT02727330014", "description": "Company ID or VAT number" }
          ]
        },
        "description": "Get detailed company data by ID or VAT number."
      }
    },
    {
