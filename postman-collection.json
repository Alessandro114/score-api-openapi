          "protocol": "https",
          "host": ["score", "get-scala", "com"],
          "path": ["api", "search"],
          "query": [
            { "key": "q", "value": "restaurant" },
            { "key": "country", "value": "IT" },
            { "key": "nace", "value": "56.10", "description": "NACE code for restaurants" },
            { "key": "limit", "value": "10" }
          ]
        }
      }
    },
    {
      "name": "Lookup by VAT Number",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
