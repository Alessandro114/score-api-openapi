          "protocol": "https",
          "host": ["score", "get-scala", "com"],
          "path": ["api", "search"],
          "query": [
            { "key": "q", "value": "Siemens" },
            { "key": "country", "value": "DE" },
            { "key": "status", "value": "active", "description": "Filter: active or inactive" },
            { "key": "limit", "value": "5" }
          ]
