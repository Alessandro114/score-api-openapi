{
  "info": {
    "name": "SCALA Score API — 250M+ Company Records",
    "description": "Search and enrich company data from 250M+ business records across 50+ countries.\n\nRevenue, employees, credit scores, NACE codes, legal forms — sourced from official government business registries.\n\n**Free tier**: 50 lookups/month, no signup needed.\n\nTools: npm (enrich-companies, company-lookup, scala-mcp-server), PyPI (enrich-companies, scala-score), Chrome Extension, GitHub Action.\n\nMore info: https://github.com/Alessandro114/score-api-openapi",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Search Companies",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://score.get-scala.com/api/search?q=Ferrero&country=IT&limit=5",
          "protocol": "https",
          "host": ["score", "get-scala", "com"],
          "path": ["api", "search"],
          "query": [
            { "key": "q", "value": "Ferrero", "description": "Company name, VAT number, or keyword" },
            { "key": "country", "value": "IT", "description": "ISO 2-letter country code (optional)" },
            { "key": "limit", "value": "5", "description": "Max results 1-100 (default 10)" }
          ]
        },
        "description": "Search companies by name, VAT number, or keyword. Filter by country, NACE code, or status."
      }
    },
    {
      "name": "Search by NACE Industry",
      "request": {
        "method": "GET",
